{
  "name": "ablogcms/plugin-skeleton",
  "description": "Skeleton for a-blog cms plugin development, with a PHPUnit setup based on the bundled SamplePlugin",
  "type": "project",
  "license": "MIT",
  "authors": [
    {
      "name": "appleple",
      "email": "info@appleple.com"
    }
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "ext-zip": "*",
    "ablogcms/testing-framework": "3.2.*",
    "phpcompatibility/php-compatibility": "^10.0@dev",
    "phpstan/phpstan": "^2.1",
    "phpstan/phpstan-strict-rules": "^2.0",
    "squizlabs/php_codesniffer": "^3.9"
  },
  "autoload": {
    "psr-4": {
      "Acms\\Plugins\\Skeleton\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Acms\\Plugins\\Skeleton\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php -r \"@unlink('LICENSE'); @unlink('CONTRIBUTING.md');\"",
      "@php scripts/namespace.php"
    ],
    "test": "vendor/bin/phpunit",
    "lint": "vendor/bin/phpcs --standard=phpcs.xml.dist",
    "format": "vendor/bin/phpcbf --standard=phpcs.xml.dist",
    "analyse": "vendor/bin/phpstan analyse",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ],
    "package": "@php scripts/package.php",
    "version:set": "@php scripts/version.php",
    "release:patch": "@php scripts/release.php patch",
    "release:minor": "@php scripts/release.php minor",
    "release:major": "@php scripts/release.php major"
  },
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpcsstandards/composer-installer": true
    },
    "sort-packages": true,
    "platform": {
      "php": "8.5.0"
    }
  }
}
