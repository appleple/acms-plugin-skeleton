{
  "name": "appleple/acms-plugin-skeleton",
  "description": "Skeleton for a-blog cms plugin development, with a PHPUnit setup based on the bundled SamplePlugin",
  "type": "project",
  "license": "proprietary",
  "authors": [
    {
      "name": "appleple",
      "email": "info@appleple.com"
    }
  ],
  "require": {
    "php": "^8.1"
  },
  "require-dev": {
    "appleple/acms-testing-framework": "3.2.*",
    "phpstan/phpstan": "^2.1",
    "squizlabs/php_codesniffer": "^3.9",
    "phpcompatibility/php-compatibility": "*"
  },
  "autoload": {
    "psr-4": {
      "Acms\\Plugins\\Skeleton\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Acms\\Plugins\\Skeleton\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "@php scripts/rename-namespace.php"
    ],
    "post-install-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility",
    "post-update-cmd": "\"vendor/bin/phpcs\" --config-set installed_paths vendor/phpcompatibility/php-compatibility",
    "test": "vendor/bin/phpunit",
    "lint": "vendor/bin/phpcs --standard=phpcs.xml",
    "format": "vendor/bin/phpcbf --standard=phpcs.xml",
    "analyse": "vendor/bin/phpstan analyse",
    "check": [
      "@lint",
      "@analyse",
      "@test"
    ]
  },
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.5.0"
    }
  }
}
